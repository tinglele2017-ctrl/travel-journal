// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== 核心实体 ====================

model User {
  id            String    @id @default(cuid())
  username      String    @unique
  avatar        String?
  bio           String?
  location      String?   // 常居地
  countriesVisited Json?  // 去过的国家 JSON 数组
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关系
  journals      TravelJournal[]
  comments      Comment[]
  collections   Collection[]
  likes         Like[]
}

model TravelJournal {
  id            String    @id @default(cuid())
  title         String
  coverImage    String?
  summary       String?
  content       String?   @db.Text
  status        String    @default("draft") // draft | published | archived
  viewCount     Int       @default(0)
  isPublic      Boolean   @default(true)
  startDate     DateTime?
  endDate       DateTime?

  // 统计字段（冗余，用于快速展示）
  totalDays     Int       @default(0)
  totalCost     Float     @default(0)
  likeCount     Int       @default(0)
  commentCount  Int       @default(0)
  collectCount  Int       @default(0)

  createdAt     DateTime  @default(now())
  publishedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  // 关系
  author        User      @relation(fields: [authorId], references: [id])
  authorId      String
  days          JournalDay[]
  comments      Comment[]
  collections   Collection[]
  medias        Media[]
  tags          JournalTag[]
  pois          JournalPOI[]
  expenses      JournalExpense[]
  likes         Like[]
  destination   Destination? @relation(fields: [destinationId], references: [id])
  destinationId String?
}

model JournalDay {
  id            String    @id @default(cuid())
  dayNumber     Int
  title         String?
  content       String?   @db.Text
  date          DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关系
  journal       TravelJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  journalId     String
  pois          JournalPOI[]
  expenses      JournalExpense[]
  medias        Media[]
}

model Destination {
  id            String    @id @default(cuid())
  name          String
  nameEn        String?
  level         String    @default("city") // continent | country | city
  country       String?
  region        String?
  description   String?
  bestSeason    String?   // 最佳旅行时间
  latitude      Float?
  longitude     Float?
  coverImage    String?
  journalCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 层级关系（支持三级：洲→国家→城市）
  parent        Destination?  @relation("DestinationHierarchy", fields: [parentId], references: [id])
  parentId      String?
  children      Destination[] @relation("DestinationHierarchy")

  // 关系
  journals      TravelJournal[]
}

model Comment {
  id            String    @id @default(cuid())
  content       String    @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 关系
  author        User      @relation(fields: [authorId], references: [id])
  authorId      String
  journal       TravelJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  journalId     String
  parent        Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  parentId      String?
  replies       Comment[] @relation("CommentReplies")
}

model Collection {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())

  // 关系
  user          User      @relation(fields: [userId], references: [id])
  userId        String
  journal       TravelJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  journalId     String

  @@unique([userId, journalId])
}

model Media {
  id            String    @id @default(cuid())
  url           String
  thumbnailUrl  String?
  type          String    @default("image") // image | video
  caption       String?
  width         Int?
  height        Int?
  size          Int?       // 文件大小（字节）
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())

  // 关系
  journal       TravelJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  journalId     String
  day           JournalDay? @relation(fields: [dayId], references: [id], onDelete: SetNull)
  dayId         String?
  poi           JournalPOI?
}

model Tag {
  id            String    @id @default(cuid())
  name          String    @unique
  type          String    @default("theme") // destination | theme
  journalCount  Int       @default(0)
  createdAt     DateTime  @default(now())

  // 关系
  journals      JournalTag[]
}

model JournalTag {
  id            String    @id @default(cuid())

  // 关系
  journal       TravelJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  journalId     String
  tag           Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId         String

  @@unique([journalId, tagId])
}

model JournalPOI {
  id            String    @id @default(cuid())
  name          String
  address       String?
  latitude      Float?
  longitude     Float?
  description   String?
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())

  // 关系
  journal       TravelJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  journalId     String
  day           JournalDay? @relation(fields: [dayId], references: [id], onDelete: SetNull)
  dayId         String?
  media         Media?    @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  mediaId       String?   @unique
}

model JournalExpense {
  id            String    @id @default(cuid())
  category      String    // 交通 | 住宿 | 餐饮 | 门票 | 购物 | 其他
  amount        Float
  currency      String    @default("CNY")
  description   String?
  date          DateTime?
  createdAt     DateTime  @default(now())

  // 关系
  journal       TravelJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  journalId     String
  day           JournalDay? @relation(fields: [dayId], references: [id], onDelete: SetNull)
  dayId         String?
}

model Like {
  id            String    @id @default(cuid())
  createdAt     DateTime  @default(now())

  // 关系
  user          User      @relation(fields: [userId], references: [id])
  userId        String
  journal       TravelJournal @relation(fields: [journalId], references: [id], onDelete: Cascade)
  journalId     String

  @@unique([userId, journalId])
}
